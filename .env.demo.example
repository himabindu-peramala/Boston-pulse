# Boston Pulse — demo environment
# Usage:
#   cp .env.demo.example .env.demo
#   # edit .env.demo
#   make demo-up       # create project + billing + infra + VM
#   make demo-down     # teardown

# ─── Required ───────────────────────────────────────────────────────
# A brand-new GCP project id (must be globally unique, 6–30 lowercase chars).
GCP_PROJECT_ID=boston-pulse-demo-0421

# Your billing account id — find via: gcloud billing accounts list
GCP_BILLING_ACCOUNT=XXXX-XXXX-XXXX-XXXX

# GitHub repo in owner/repo format — used for WIF binding.
GITHUB_REPOSITORY=himabindu-peramala/Boston-pulse

# ─── Optional (defaults shown) ──────────────────────────────────────
GCP_REGION=us-east1
VM_ZONE=us-east1-d
VM_MACHINE_TYPE=e2-standard-4

# Slack bot token for Terraform-managed notification channel (optional).
# SLACK_AUTH_TOKEN=xoxb-...
