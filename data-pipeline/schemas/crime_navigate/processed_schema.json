{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Navigate Crime Processed Schema",
  "type": "object",
  "properties": {
    "incident_number": {"type": "string", "description": "Primary key."},
    "offense_description": {"type": ["string", "null"], "description": "Original description text."},
    "occurred_on_date": {"type": "datetime", "format": "date-time", "description": "UTC datetime.", "watermark_field": true},
    "shooting": {"type": "boolean", "description": "True if SHOOTING was '1'."},
    "shooting_raw": {"type": ["string", "null"], "description": "Original string value preserved."},
    "lat": {"type": ["number", "null"], "minimum": 42.2, "maximum": 42.4},
    "long": {"type": ["number", "null"], "minimum": -71.2, "maximum": -70.9},
    "hour": {"type": "integer", "minimum": 0, "maximum": 23},
    "day_of_week": {"type": "string", "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"]},
    "district": {"type": ["string", "null"], "description": "Kept for fairness checking only."},
    "severity_weight": {"type": "number", "minimum": 0.0, "description": "Computed from offense_description and shooting."},
    "h3_index": {"type": ["string", "null"], "description": "H3 res-9 cell. Null if coordinates invalid."},
    "hour_bucket": {"type": ["integer", "null"], "minimum": 0, "maximum": 5}
  },
  "required": ["incident_number", "occurred_on_date", "shooting", "severity_weight"],
  "additionalProperties": false,
  "metadata": {
    "dataset": "crime_navigate",
    "stage": "processed",
    "version": "1.0.1"
  }
}
