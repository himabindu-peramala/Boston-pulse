{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Navigate Crime Features Schema",
  "type": "object",
  "properties": {
    "h3_index": {"type": "string", "description": "H3 res-9 cell index. Part of composite primary key."},
    "hour_bucket": {"type": "integer", "minimum": 0, "maximum": 5, "description": "Part of composite primary key."},
    "computed_date": {"type": "string", "format": "date", "description": "Part of composite primary key."},
    "weighted_score_3d": {"type": "number", "minimum": 0.0},
    "weighted_score_10d": {"type": "number", "minimum": 0.0},
    "weighted_score_30d": {"type": "number", "minimum": 0.0},
    "weighted_score_90d": {"type": "number", "minimum": 0.0},
    "incident_count_30d": {"type": "integer", "minimum": 0},
    "trend_3v10": {"type": "number", "minimum": 0.0, "maximum": 10.0},
    "trend_10v30": {"type": "number", "minimum": 0.0, "maximum": 5.0},
    "trend_30v90": {"type": "number", "minimum": 0.0, "maximum": 3.0},
    "violent_score_30d": {"type": "number", "minimum": 0.0},
    "gun_incident_count_30d": {"type": "integer", "minimum": 0},
    "high_severity_ratio_30d": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "night_score_ratio": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "evening_score_ratio": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "weekend_score_ratio": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "neighbor_weighted_score_30d": {"type": "number", "minimum": 0.0},
    "neighbor_trend_3v10": {"type": "number", "minimum": 0.0},
    "neighbor_gun_count_30d": {"type": "number", "minimum": 0.0},
    "cell_score_yesterday": {"type": "number", "minimum": 0.0},
    "cell_score_7d_ago": {"type": "number", "minimum": 0.0},
    "neighbor_score_yesterday": {"type": "number", "minimum": 0.0},
    "risk_score": {"type": "number", "minimum": 0.0, "maximum": 100.0},
    "risk_tier": {"type": "string", "enum": ["LOW", "MEDIUM", "HIGH"]}
  },
  "required": ["h3_index", "hour_bucket", "computed_date", "risk_score", "risk_tier"],
  "additionalProperties": false,
  "metadata": {
    "dataset": "crime_navigate",
    "stage": "features",
    "version": "1.0.0",
    "primary_key": ["h3_index", "hour_bucket", "computed_date"]
  }
}
